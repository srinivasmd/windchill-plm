# Zephyr Skill - Git Ignore File

# =============================================================================
# Ignore deprecated/old directories
# =============================================================================

# Old/deprecated scripts - DO NOT USE
scripts/old/

# Old/deprecated references
references/old/

# =============================================================================
# Ignore backup and temporary files
# =============================================================================

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# Virtual environments
venv/
.venv/
env/
.env/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# =============================================================================
# Ignore sensitive configuration
# =============================================================================

# Config files with credentials (keep template)
config.json
config.local.json
*.credentials.json

# =============================================================================
# Ignore generated files (can be regenerated)
# =============================================================================

# Log files
*.log
logs/

# Test outputs
test_output/
temp/
tmp/

# =============================================================================
# Keep these directories (do not ignore)
# =============================================================================

# Keep reference metadata XML files
!references/**/*.xml
!references/**/*.md
!references/**/*.json

# Keep domain clients
!scripts/domains/**/
!scripts/windchill_base.py

# Keep query scripts
!scripts/query_*.py
