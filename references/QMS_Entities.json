      "description": "Quality action items for tracking quality-related tasks",
      "endpoint": "/QMS/QualityActions",
      "operations": ["READ", "CREATE", "UPDATE"],
      "properties": {
        "ID": {
          "type": "String",
          "description": "Object identifier (OID)",
          "constraints": ["ReadOnly", "Key"]
        },
        "Name": {
          "type": "String",
          "description": "Quality Action name"
        },
        "Number": {
          "type": "String",
          "description": "Quality Action number"
        },
        "Description": {
          "type": "String",
          "description": "Detailed description"
        },
        "State": {
          "type": "EnumType",
          "description": "Lifecycle state",
          "constraints": ["ReadOnly"],
          "possibleValues": ["OPEN", "IN_PROGRESS", "COMPLETED", "CANCELLED"]
        },
        "LifeCycleTemplateName": {
          "type": "String",
          "description": "Lifecycle template name",
          "constraints": ["ReadOnly"]
        },
        "Priority": {
          "type": "EnumType",
          "description": "Priority level",
          "possibleValues": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
        },
        "Category": {
          "type": "EnumType",
          "description": "Category of action"
        },
        "DueDate": {
          "type": "DateTimeOffset",
          "description": "Due date for completion"
        },
        "CompletionDate": {
          "type": "DateTimeOffset",
          "description": "Actual completion date"
        },
        "FolderLocation": {
          "type": "String",
          "description": "Folder path in Windchill"
        },
        "MasterID": {
          "type": "String",
          "description": "Master ID",
          "constraints": ["ReadOnly"]
        },
        "CreatedBy": {
          "type": "String",
          "description": "Created by",
          "constraints": ["ReadOnly"]
        },
        "ModifiedBy": {
          "type": "String",
          "description": "Modified by",
          "constraints": ["ReadOnly"]
        },
        "CreatedOn": {
          "type": "DateTimeOffset",
          "description": "Creation timestamp",
          "constraints": ["ReadOnly"]
        },
        "LastModified": {
          "type": "DateTimeOffset",
          "description": "Last modification timestamp",
          "constraints": ["ReadOnly"]
        }
      },
      "navigationProperties": {
        "Context": {
          "type": "PTC.DataAdmin.Container",
          "description": "Container context"
        },
        "Creator": {
          "type": "PTC.PrincipalMgmt.User",
          "description": "Creator user"
        },
        "Modifier": {
          "type": "PTC.PrincipalMgmt.User",
          "description": "Modifier user"
        },
        "Owner": {
          "type": "PTC.PrincipalMgmt.User",
          "description": "Owner user"
        },
        "QualityIssue": {
          "type": "QualityIssue",
          "description": "Related Quality Issue"
        },
        "RelatedProducts": {
          "type": "Collection(RelatedProduct)",
          "description": "Related Products"
        }
      }
