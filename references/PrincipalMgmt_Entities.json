{
  "domain": "PrincipalMgmt",
  "description": "Windchill Principal Management Domain - Users, Groups, Organizations, and Roles",
  "entities": {
    "User": {
      "description": "Windchill user account with profile information",
      "endpoint": "/PrincipalMgmt/Users",
      "operations": ["READ"],
      "properties": {
        "ID": {
          "type": "String",
          "description": "Object identifier (OID)",
          "constraints": ["ReadOnly", "Key"]
        },
        "Name": {
          "type": "String",
          "description": "Username (login name)"
        },
        "FullName": {
          "type": "String",
          "description": "User's full display name"
        },
        "Email": {
          "type": "String",
          "description": "User's email address"
        },
        "FirstName": {
          "type": "String",
          "description": "User's first name"
        },
        "LastName": {
          "type": "String",
          "description": "User's last name"
        },
        "Title": {
          "type": "String",
          "description": "Job title"
        },
        "Organization": {
          "type": "String",
          "description": "Organization name"
        },
        "Department": {
          "type": "String",
          "description": "Department name"
        },
        "Location": {
          "type": "String",
          "description": "Physical location"
        },
        "Phone": {
          "type": "String",
          "description": "Phone number"
        },
        "Fax": {
          "type": "String",
          "description": "Fax number"
        },
        "Pager": {
          "type": "String",
          "description": "Pager number"
        },
        "Disabled": {
          "type": "Boolean",
          "description": "Whether account is disabled"
        },
        "ServiceUser": {
          "type": "Boolean",
          "description": "Whether this is a service account"
        },
        "CreatedOn": {
          "type": "DateTimeOffset",
          "description": "Account creation timestamp",
          "constraints": ["ReadOnly"]
        },
        "LastModified": {
          "type": "DateTimeOffset",
          "description": "Last modification timestamp",
          "constraints": ["ReadOnly"]
        },
        "TypeIcon": {
          "type": "Icon",
          "description": "Type icon",
          "constraints": ["ReadOnly", "NonFilterable", "NonSortable"]
        },
        "ObjectType": {
          "type": "String",
          "description": "Object type",
          "constraints": ["ReadOnly", "NonFilterable", "NonSortable"]
        }
      },
      "navigationProperties": {
        "Context": {
          "type": "PTC.DataAdmin.Container",
          "description": "Container context"
        },
        "Organization": {
          "type": "Organization",
          "description": "Organization"
        },
        "Groups": {
          "type": "Collection(Group)",
          "description": "Groups the user belongs to"
        },
        "Roles": {
          "type": "Collection(Role)",
          "description": "Roles assigned to the user"
        }
      }
    },
    "Group": {
      "description": "User group for access control and team management",
      "endpoint": "/PrincipalMgmt/Groups",
      "operations": ["READ"],
      "properties": {
        "ID": {
          "type": "String",
          "description": "Object identifier (OID)",
          "constraints": ["ReadOnly", "Key"]
        },
        "Name": {
          "type": "String",
          "description": "Group name"
        },
        "Description": {
          "type": "String",
          "description": "Group description"
        },
        "GroupType": {
          "type": "EnumType",
          "description": "Type of group",
          "possibleValues": ["STATIC", "DYNAMIC"]
        },
        "ServiceGroup": {
          "type": "Boolean",
          "description": "Whether this is a service group"
        },
        "CreatedOn": {
          "type": "DateTimeOffset",
          "description": "Creation timestamp",
          "constraints": ["ReadOnly"]
        },
        "LastModified": {
          "type": "DateTimeOffset",
          "description": "Last modification timestamp",
          "constraints": ["ReadOnly"]
        },
        "TypeIcon": {
          "type": "Icon",
          "description": "Type icon",
          "constraints": ["ReadOnly", "NonFilterable", "NonSortable"]
        },
        "ObjectType": {
          "type": "String",
          "description": "Object type",
          "constraints": ["ReadOnly", "NonFilterable", "NonSortable"]
        }
      },
      "navigationProperties": {
        "Context": {
          "type": "PTC.DataAdmin.Container",
          "description": "Container context"
        },
        "ParentGroup": {
          "type": "Group",
          "description": "Parent group (nested groups)"
        },
        "ChildGroups": {
          "type": "Collection(Group)",
          "description": "Child groups"
        },
        "Members": {
          "type": "Collection(User)",
          "description": "Users in this group"
        },
        "Roles": {
          "type": "Collection(Role)",
          "description": "Roles assigned to this group"
        }
      }
    },
    "Organization": {
      "description": "Organizational unit for user management",
      "endpoint": "/PrincipalMgmt/Organizations",
      "operations": ["READ"],
      "properties": {
        "ID": {
          "type": "String",
          "description": "Object identifier (OID)",
          "constraints": ["ReadOnly", "Key"]
        },
        "Name": {
          "type": "String",
          "description": "Organization name"
        },
        "Description": {
          "type": "String",
          "description": "Organization description"
        },
        "OrganizationType": {
          "type": "EnumType",
          "description": "Type of organization"
        },
        "CreatedOn": {
          "type": "DateTimeOffset",
          "description": "Creation timestamp",
          "constraints": ["ReadOnly"]
        },
        "LastModified": {
          "type": "DateTimeOffset",
          "description": "Last modification timestamp",
          "constraints": ["ReadOnly"]
        }
      },
      "navigationProperties": {
        "Context": {
          "type": "PTC.DataAdmin.Container",
          "description": "Container context"
        },
        "ParentOrganization": {
          "type": "Organization",
          "description": "Parent organization"
        },
        "ChildOrganizations": {
          "type": "Collection(Organization)",
          "description": "Child organizations"
        },
        "Users": {
          "type": "Collection(User)",
          "description": "Users in this organization"
        },
        "Groups": {
          "type": "Collection(Group)",
          "description": "Groups in this organization"
        }
      }
    },
    "Role": {
      "description": "Role definition for access control",
      "endpoint": "/PrincipalMgmt/Roles",
      "operations": ["READ"],
      "properties": {
        "ID": {
          "type": "String",
          "description": "Object identifier (OID)",
          "constraints": ["ReadOnly", "Key"]
        },
        "Name": {
          "type": "String",
          "description": "Role name"
        },
        "Description": {
          "type": "String",
          "description": "Role description"
        },
        "RoleType": {
          "type": "EnumType",
          "description": "Type of role",
          "possibleValues": ["SYSTEM", "CUSTOM"]
        },
        "CreatedOn": {
          "type": "DateTimeOffset",
          "description": "Creation timestamp",
          "constraints": ["ReadOnly"]
        },
        "LastModified": {
          "type": "DateTimeOffset",
          "description": "Last modification timestamp",
          "constraints": ["ReadOnly"]
        }
      },
      "navigationProperties": {
        "Context": {
          "type": "PTC.DataAdmin.Container",
          "description": "Container context"
        },
        "Users": {
          "type": "Collection(User)",
          "description": "Users with this role"
        },
        "Groups": {
          "type": "Collection(Group)",
          "description": "Groups with this role"
        }
      }
    }
  }
}
